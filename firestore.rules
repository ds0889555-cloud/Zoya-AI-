rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidMessage(data) {
      return data.sender in ['user', 'zoya']
        && data.text is string && data.text.size() <= 5000
        && data.createdAt == request.time
        && data.keys().hasAll(['sender', 'text', 'createdAt'])
        && data.keys().size() == 3;
    }

    function isValidProfile(data) {
      return data.displayName is string && data.displayName.size() <= 100
        && (data.email == null || (data.email is string && data.email.size() <= 150))
        && data.keys().hasAll(['displayName', 'email'])
        && (data.lastLogin == null || data.lastLogin == request.time);
    }

    // --- Rules ---

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'email', 'preferences', 'lastLogin']);
    }

    // Messages
    match /users/{userId}/messages/{messageId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMessage(incoming()) && isValidId(messageId);
      allow delete: if isOwner(userId);
    }
  }
}
